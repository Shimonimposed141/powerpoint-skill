  {"id": "f07-biperm-props", "latex": "\\text{Soundness: } O\\!\\left(\\frac{\\log n}{|\\mathbb{F}|}\\right), \\quad \\text{Prover: } O(n), \\quad \\text{Verifier: } O(\\log n)", "mode": "display", "render": "image", "fg_color": "1A1A2E"},
  {"id": "f08-mulperm-decompose", "latex": "\\tilde{1}_\\sigma(X, Y) = \\prod_{j=1}^{\\ell} \\tilde{1}_j(X, Y^{(j)})", "mode": "display"},
  {"id": "f09-partial-prod", "latex": "p(x, \\langle j \\rangle) := \\prod_{i=1}^{\\mu/\\ell} \\mathrm{eq}\\bigl(\\alpha(\\langle j' + i \\rangle),\\, \\tilde{\\sigma}_{[\\mu]}(\\langle j' + i \\rangle, x)\\bigr)", "mode": "display"},
  {"id": "f10-first-sumcheck", "latex": "\\sum_{x \\in \\mathcal{B}_\\mu} f(x) \\cdot \\prod_{j \\in [\\ell]} \\tilde{p}(x, \\langle j \\rangle) = g(\\alpha)", "mode": "display"},
  {"id": "f11-second-sumcheck", "latex": "\\sum_{x \\in \\mathcal{B}_\\mu, \\, j \\in [\\ell]} \\mathrm{eq}(\\beta', x \\| \\langle j \\rangle) \\prod_{i=1}^{\\mu/\\ell} \\mathrm{eq}\\bigl(\\alpha(\\langle j'+i \\rangle),\\, \\tilde{\\sigma}_{[\\mu]}(\\langle j'+i \\rangle, x)\\bigr) = S_{\\tilde{p}}", "mode": "display", "render": "image", "fg_color": "1A1A2E"},
  {"id": "f12-total-cost", "latex": "\\underbrace{n \\cdot \\tilde{O}(\\ell)}_{\\text{1st sumcheck}} + \\underbrace{n \\cdot \\tilde{O}(\\mu/\\ell) + \\ell \\cdot 2^\\ell}_{\\text{2nd sumcheck}} = n \\cdot \\tilde{O}(\\ell + \\mu/\\ell) + \\ell \\cdot 2^\\ell", "mode": "display", "render": "image", "fg_color": "1A1A2E"},
  {"id": "f13-set-ell", "latex": "\\ell = \\sqrt{\\mu} \\;\\Longrightarrow\\; n \\cdot \\tilde{O}(\\sqrt{\\log n})", "mode": "display"},
