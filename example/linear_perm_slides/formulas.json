  {"id": "f21-degree-tradeoff", "latex": "\\underbrace{\\deg 1}_{n^2 \\text{ size}} \\longleftrightarrow \\underbrace{\\deg 2}_{\\text{BiPerm}} \\longleftrightarrow \\underbrace{\\deg \\ell}_{\\text{MulPerm}} \\longleftrightarrow \\underbrace{\\deg \\mu}_{\\text{HyperPlonk}}", "mode": "display", "render": "image", "fg_color": "1A1A2E"},
