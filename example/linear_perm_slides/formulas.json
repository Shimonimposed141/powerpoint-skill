  {"id": "f16-binmap", "latex": "\\sum_{x \\in \\mathcal{B}_\\mu,\\, i \\in [\\mu]} \\mathrm{eq}\\bigl((x, \\langle i \\rangle), s\\bigr) \\cdot \\tilde{\\sigma}_{[\\mu]}(i, x) \\bigl(1 - \\tilde{\\sigma}_{[\\mu]}(i, x)\\bigr) = 0", "mode": "display", "render": "image", "fg_color": "1A1A2E"},
