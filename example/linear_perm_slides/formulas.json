[
  {"id": "f01-sumcheck-core", "latex": "\\sum_{x \\in \\mathcal{B}_\\mu} f(x) \\cdot \\tilde{1}_\\sigma(x, \\alpha) = g(\\alpha)", "mode": "display"},
  {"id": "f02-indicator", "latex": "1_\\sigma(X, Y) = \\begin{cases} 1 & \\sigma(X) = Y \\\\ 0 & \\text{otherwise} \\end{cases}", "mode": "display", "render": "image", "fg_color": "1A1A2E"},
  {"id": "f03-degree-mu", "latex": "\\tilde{1}_\\sigma(X, Y) = \\prod_{i=1}^{\\mu} \\mathrm{eq}(\\tilde{\\sigma}_i(X),\\, Y_i)", "mode": "display"},
  {"id": "f04-eq-poly", "latex": "\\mathrm{eq}(X, Y) = \\prod_{i=1}^{\\mu} \\bigl(X_i Y_i + (1 - X_i)(1 - Y_i)\\bigr)", "mode": "display"},
